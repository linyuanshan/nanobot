HATCHERY_DATABASE_PATH=workspace/hatchery/hatchery.db
HATCHERY_APPROVAL_PROVIDER=local
HATCHERY_ENABLE_SCHEDULER=true
HATCHERY_SCHEDULER_INTERVAL_SEC=1.0
HATCHERY_SERVICE_NAME=hatchery-service

HATCHERY_MQTT_ENABLED=true
HATCHERY_MQTT_HOST=127.0.0.1
HATCHERY_MQTT_PORT=1883
HATCHERY_MQTT_KEEPALIVE_SEC=30
HATCHERY_MQTT_CLIENT_ID=hatchery-phase1
HATCHERY_MQTT_TOPIC_PREFIX=hatchery
HATCHERY_MQTT_QOS=1
HATCHERY_MQTT_RETAIN=false

HATCHERY_AUTH_ENABLED=false
HATCHERY_AUTH_TOKENS_JSON={"viewer-token":"viewer","operator-token":"operator","admin-token":"admin"}

HATCHERY_LOG_DIR=workspace/hatchery/logs
HATCHERY_LOG_LEVEL=INFO
HATCHERY_LOG_MAX_BYTES=2000000
HATCHERY_LOG_BACKUP_COUNT=5

HATCHERY_REAL_ADAPTER_ENABLED=false
HATCHERY_REAL_DEFAULT_TIMEOUT_SEC=30
HATCHERY_REAL_RELAY_MAP_JSON={}
HATCHERY_REAL_RELAY_MAP_PATH=
HATCHERY_REAL_STRICT_MAPPING=false

HATCHERY_BRIDGE_SERVICE_URL=http://127.0.0.1:8090
HATCHERY_BRIDGE_HOST=127.0.0.1
HATCHERY_BRIDGE_PORT=8190
HATCHERY_BRIDGE_NAME=hatchery-bridge
HATCHERY_BRIDGE_AUTH_ENABLED=false
HATCHERY_BRIDGE_AUTH_TOKENS_JSON={"bridge-token":"operator"}
HATCHERY_BRIDGE_SERVICE_TOKEN=
HATCHERY_BRIDGE_SERVICE_ACTOR=bridge-service